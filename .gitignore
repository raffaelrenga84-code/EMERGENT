# =====================================================================
#  FAMMY — .gitignore
#  Sostituisce la versione corrotta (25 blocchi ripetuti + righe "-e")
# =====================================================================

# Credenziali e ambiente — MAI committare
.env
.env.*
*.env
credentials.json
.credentials
*.pem
*.key

# Dipendenze
node_modules/
.pnp
.pnp.js

# Build
dist/
dist-ssr/
build/
*.local

# Cache e strumenti
.cache/
.parcel-cache/
.eslintcache
.vercel
.turbo

# Log
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Python (residui emergent.sh)
__pycache__/
*.py[cod]
venv/
.venv/

# Test e temporanei
coverage/
.nyc_output/
*.tmp
tmp/
